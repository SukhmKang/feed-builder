# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of your deployed frontend (used for CORS)
FRONTEND_URL=https://feed-builder.vercel.app

# Database for the backend.
# Local dev can keep SQLite:
# DATABASE_URL=sqlite:///./feed_builder_app.db
# Production should use managed Postgres:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./feed_builder_app.db

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Sources ───────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
TAVILY_API_KEY=
# Optional comma-separated rotation list. If set, this is preferred over TAVILY_API_KEY.
TAVILY_API_KEYS=
NITTER_BASE=https://nitter.sknitterinstance.com

# ── Rotating proxy (Webshare) ─────────────────────────────────────────────────
# Used by youtube_scraper.py and discover_feeds.py
PROXY_USERNAME=
PROXY_PASSWORD=
